{
  "manifest_version": 3,
  "name": "UTR Rating Lookup",
  "version": "8.4",
  "description": "UTR lookup on USTA roster & scorecard pages",
  "permissions": [
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "https://api.utrsports.net/*",
    "https://app.utrsports.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "UTR Rating Lookup"
  },
  "content_scripts": [
    {
      "matches": [
        "*://leagues.ustanorcal.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ]
}